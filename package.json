{
  "name": "learning-surface",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n server,ui -c blue,green \"npx tsx src/server/cli.ts ./session 8081\" \"vite\"",
    "dev:ui": "vite",
    "dev:server": "npx tsx src/server/cli.ts ./session 8081",
    "build": "tsc -p tsconfig.server.json && vite build",
    "start": "NODE_ENV=production node dist/server/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@tailwindcss/vite": "^4.2.1",
    "chokidar": "^4.0.0",
    "diff": "^7.0.0",
    "env-paths": "^4.0.0",
    "gray-matter": "^4.0.3",
    "katex": "^0.16.0",
    "markdown-it": "^14.0.0",
    "mermaid": "^11.0.0",
    "nanoid": "^5.1.6",
    "openai": "^6.27.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "shiki": "^3.0.0",
    "ws": "^8.0.0",
    "zod": "^3.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/typography": "^0.5.0",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.0.0",
    "@types/diff": "^7.0.0",
    "@types/http-proxy": "^1.17.17",
    "@types/markdown-it": "^14.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/ws": "^8.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "http-proxy": "^1.18.1",
    "jsdom": "^26.0.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.57.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  }
}
